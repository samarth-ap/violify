rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ============================================
    // USER PROFILES
    // ============================================
    match /users/{userId} {
      // Users can read and write their own profile
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ============================================
    // USER LESSONS
    // ============================================
    match /users/{userId}/lessons/{lessonId} {
      // Users can read, create, update their own lessons
      allow read, create, update: if isOwner(userId);
      // Users can delete their own lessons
      allow delete: if isOwner(userId);
    }

    // ============================================
    // PRACTICE SESSIONS
    // ============================================
    match /users/{userId}/practice-sessions/{sessionId} {
      // Users can read, create, update their own practice sessions
      allow read, create, update: if isOwner(userId);
      // Users can delete their own practice sessions
      allow delete: if isOwner(userId);
    }

    // ============================================
    // ANALYTICS
    // ============================================
    match /users/{userId}/analytics/{document=**} {
      // Users can read and write their own analytics
      allow read, write: if isOwner(userId);
    }

    // ============================================
    // ACHIEVEMENTS
    // ============================================
    match /users/{userId}/achievements/{achievementId} {
      // Users can read and create their own achievements
      allow read, create: if isOwner(userId);
      // Prevent deletion of achievements
      allow delete: if false;
    }
  }
}
